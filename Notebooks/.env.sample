# Microsoft Foundry ITSM - Environment Variables
# Copy this file to .env and fill in your values
#
# After running deploy.ps1, get these values from:
#   cd infra && terraform output

# AI Foundry project endpoint (from terraform output: ai_account_endpoint)
PROJECT_ENDPOINT=https://YOUR_AI_ACCOUNT.cognitiveservices.azure.com/

# Model deployment name (default GPT-4.1 deployment)
MODEL_DEPLOYMENT_NAME=gpt-4.1

# APIM MCP Server URL
# After configuring the MCP server in APIM (Azure Portal → APIM → APIs → MCP Servers),
# copy the MCP server endpoint URL here
MCP_SERVER_URL=https://YOUR_APIM.azure-api.net/mcp

# Label for the MCP server (used to identify it in agent tool calls)
MCP_SERVER_LABEL=halo-itsm-mcp
